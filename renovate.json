{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Renovate owns dependency updates for Go, Gradle, GitHub Actions, Docker images, and runtime tools.",
  "extends": ["config:recommended"],
  "enabledManagers": ["gomod", "gradle", "github-actions", "dockerfile", "custom.regex"],
  "dependencyDashboard": true,
  "minimumReleaseAge": "2 days",
  "prCreation": "not-pending",
  "internalChecksFilter": "strict",
  "automergeType": "pr",
  "platformAutomerge": true,
  "prConcurrentLimit": 3,
  "prHourlyLimit": 1,
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update Python runtime tools pinned in Dockerfile.",
      "managerFilePatterns": ["/(^|/)Dockerfile$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-z-]+) packageName=(?<packageName>[^\\s]+) versioning=(?<versioning>[a-z0-9-]+)\\s+ARG [A-Z0-9_]+_VERSION=(?<currentValue>[^\\s]+)"
      ]
    }
  ],
  "packageRules": [
    {
      "description": "Automerge non-major dependency updates after required checks pass.",
      "matchUpdateTypes": ["minor", "patch", "digest", "pin", "pinDigest"],
      "automerge": true
    },
    {
      "description": "Group Go minor and patch updates.",
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "go minor and patch dependencies",
      "groupSlug": "go-minor-patch"
    },
    {
      "description": "Group Android minor and patch updates.",
      "matchManagers": ["gradle"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "android minor and patch dependencies",
      "groupSlug": "android-minor-patch"
    },
    {
      "description": "Keep Docker and runtime tool updates together.",
      "matchManagers": ["dockerfile", "custom.regex"],
      "groupName": "container runtime dependencies",
      "groupSlug": "container-runtime"
    }
  ]
}
